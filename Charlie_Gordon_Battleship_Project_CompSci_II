def select_dots(num_of_dots, rows_with_battleships, columns_with_battleships, board):
    '''
    Args:
    num_of_dots (int), rows_with_battleships(list), columns_with_battleships(list)

    Returns:
    Adds to the lists in args

    Summary:
    Selects where the random dots on the board will be
    '''
    count = num_of_dots


    #While there are still dots to put on to the baord as of the users request
    while count > 0:
        #Rows and columns are randomly decided between 0 and 4 (appears 1-5 for user)
        battleship_row = random.randint(0,4)
        battleship_column = random.randint(0,4)
        #If its empty
        if board[battleship_row][battleship_column] == 'X':
            #Add that row and column to the list - lists parallel arrays
            rows_with_battleships.append(battleship_row)
            columns_with_battleships.append(battleship_column)
            count = count-1
    


