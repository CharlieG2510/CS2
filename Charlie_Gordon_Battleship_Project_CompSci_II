def sound(noise):
    '''
    Args:
    noise(mp3)

    Returns:
    sound to the computer

    Summary:
    Plays the mp3 noise in the arguement
    '''
    #IMPORTANT NOTE, MP3 MUST BE IN YOUR FILE WITH THE CODE!!!!!!!

    #initiate the pygame import
    pygame.init()

    #begin Mixer
    pygame.mixer.init()

    #Load the mp3 sound you want
    pygame.mixer.music.load(f"{noise}.mp3")

    #Set volume
    pygame.mixer.music.set_volume(0.7)

    #Play that noise
    pygame.mixer.music.play()

    #Wait 3 seconds and end the noise
    while pygame.mixer.music.get_busy():
        pygame.time.Clock().tick(3)


    pygame.quit()



