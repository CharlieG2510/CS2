def load_and_display(file):
    '''
    Desc: Displays first 10 rows of csv
    Args: file(csv)
    Returns: first_ten_rows.csv (csv)
    '''
    #Send the file to the first line
    file.seek(1)
    counter = 0
    
    #For every line
    for line in file:
        #If 10 lines have been added
        if counter > 10:
                break
        else:
            #Makes a new csv file
            with open('first_ten_rows.csv', 'a') as tenfile:
                 #Adds to that csv file
                 tenfile.write(line)
            counter = counter + 1
        


def calc_surv(file):
    '''
    Desc: Calaculated the survival rate of people on the titanic
    Args: file(csv)
    Returns: surv_calc.csv (csv)
    
    '''
    #Send file to the first line
    file.seek(1)
    counter = 0
    survival_counter = 0
    
    
    for line in file:
        #Add one to the amount of people on the boat
        counter = counter + 1
        #Splits the line base don where , are which is automaticly used to devide csv files in excel
        row = line.strip().split(',')
        #If the passanger survived
        if row[1] == '1':
                survival_counter = survival_counter + 1
    #Subtract one because the first column is descriptive
    num_of_ppl = counter - 1
    survival_rate = survival_counter/num_of_ppl
    #Allows you to add multiple columns to an excel
    columns = f'''percentage of people who survived,   percentage of people who died,
{(survival_rate*100):.2f}%,   {((1-survival_rate)*100):.2f}%'''
    
    
    
    #Make csv and add to it
    with open('surv_calc.csv', 'w') as surv_calc_file:
        surv_calc_file.write(columns)
            

    
            
                
                
        
            
        


def gender(file):
    '''
    Desc: Figures out Gender Survival rates on titanic
    Args: file(csv)
    Returns: gender.csv (csv)
    
    '''
    #Send file to the first line
    file.seek(1)
    men = 0
    women = 0
    men_survived = 0
    women_survived = 0

    for line in file:
                #Devided the line by , which devides csv files
                row = line.strip().split(',')
                #the fifth column in the csv is the passangers sex
                sex = row[5]
                if sex == 'male':
                        men = men + 1
                        #If the man survived
                        if row[1] == '1':
                            men_survived = men_survived + 1

                elif sex == 'female':
                        women = women + 1
                        #If the woman survived
                        if row[1] == '1':
                            women_survived = women_survived + 1
                
    #Make columns which will be added to a new file
