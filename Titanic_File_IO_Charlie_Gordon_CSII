     #Make a new csv file and add the columns above into it
    with open('gender.csv', 'w') as gender_file:
         gender_file.write(columns)

def age_analysis(file):
     '''
    Desc: Figures out average age, youngest person, oldest person, average age of non survivors and survivors
    Args: file(csv)
    Returns: age_analysis.csv (csv)
    
    '''
     

     #Finds Average Age


     #Go to top of file
     file.seek(1)
     counter = 0
     total_age = 0
     for line in file:
        #Devide file based off of ,
        row = line.strip().split(',')
        #If there is an issue with the age column not being able to be turned into an int
        try:
             #Add based on how many passangers are on the ship
             counter = counter + 1
             #Age is the numerical value in row 7 (6 becuase this starts at 0) of the titanic file
             age = int(row[6])
             #Adds to the toal age of passangers
             total_age = total_age + age
        except ValueError:
             pass
        
     average_age = total_age/counter


     #Start biggest age at 0 so that any of them will be bigger and replace it
     biggest_age = 0
     #Go to top of file
     file.seek(1)
     #For revery passanger on the boat
     for line in file:
          #If there is an issue with the age column not being able to be turned into an int
          try:
               #Divide the line
               row = line.strip().split(',')
               #Find the age column in the csv
               age = int(row[6])
               #If the age there is bigger than the value already there
               if age > biggest_age:
                    #That becomes the new biggest age
                    biggest_age = age
          except ValueError:
               pass
     #Creates variable
     smallest_age = 0
     file.seek(1)
     #For every pasanger
     for line in file:
          #If there is an issue with the age column not being able to be turned into an int
          try:
               #Devide line
               row = line.strip().split(',')
               age = int(row[6])
               #If the for loop is on its first go around
               if smallest_age == 0:
                    smallest_age = age
               else:
                    #If this person is younger than the person the variable smallest age assumes is the smallest age
                    if age < smallest_age:
                         smallest_age = age
          except ValueError:
               pass
    
     
     survivors = 0
     survivor_total_age = 0
     non_survivors = 0
     non_survivor_total_age = 0
     #Go to top of file
     file.seek(1)
     #For every passanger
     for line in file:
          #If there is an issue with the age column not being able to be turned into an int
          try:
               #Devide the line
               row = line.strip().split(',')
               survived = row[1]
               age = int(row[6])
               #If the passanger survived
               if survived == ('1'):
                    survivors = survivors + 1
                    #Add there age to the total survival age
                    survivor_total_age = survivor_total_age + age
               #If the passanger died
               elif survived == ('0'):
                    non_survivors = non_survivors + 1
                    #add there age to the total dead age
                    non_survivor_total_age = non_survivor_total_age + age
          except ValueError:
               pass
     #Find the average age of survivors and non_survivors
     average_survivor_age = survivor_total_age/survivors
     average_non_survivor_age = non_survivor_total_age/non_survivors
          


     #Makes columsn that to be written later (done like this in order to have multiple columns)
     columns = f'''Average Age of Passangers, Average Age of Survivors, Average Age of Non-Survivors, Youngest Passanger, Oldest Passanger,
     {average_age:.2f}, {average_survivor_age:.2f}, {average_non_survivor_age:.2f}, {smallest_age}, {biggest_age}
     '''

     #Make a new csv and put the columns above in it
     with open('age_analysis.csv', 'w') as age_file:
          age_file.write(columns)
def classanalysis(file):
     '''
    Desc: Survival rate of each class(First, Second, Third), and average fare per class
    Args: file(csv)
    Returns: class_analysis.csv (csv)
    
    '''
     
     #Go to top of file
     file.seek(1)
     #Variables contianing all the classes, which of those classes survived, and the total fare
     first_class = 0
     second_class = 0
     third_class = 0
     first_class_survived = 0
     second_class_survived = 0
     third_class_survived = 0
     first_class_fare = 0
     second_class_fare = 0
     third_class_fare = 0

     #For every passanger
     for line in file:
                #Devide the file
                row = line.strip().split(',')
                #Each passanger class is found in row 2 of the line
                pbclass = row[2]
                #If they are in first class
                if pbclass == '1':
                        first_class = first_class + 1
                        #If there is an issue with the column not being able to be turned into an int
                        try:
                             #Add there fare (found in row 10) to the first class fare total
                             fare = float(row[10])
                             first_class_fare = first_class_fare + fare
                        except ValueError:
                             pass
                        #If they survived
                        if row[1] == '1':
                            #Add them to toal survied rate as well
                            first_class_survived = first_class_survived + 1

                #If they were second class
                elif pbclass == '2':
                        second_class = second_class + 1
                        #If there is an issue with the column not being able to be turned into an int
                        try:
                             #Add there fare to the total second class fare
                             fare = float(row[10])
                             second_class_fare = second_class_fare + fare
                        except ValueError:
                             pass
                        #Check if they sruvived and if htey did add them to the variable
                        if row[1] == '1':
                            second_class_survived = second_class_survived + 1
                #If they were third class
                elif pbclass == '3':
                        third_class = third_class + 1
                        #If there is an issue with the column not being able to be turned into an int
                        try:
                             #Add there fare to the third class total
                             fare = float(row[10])
                             third_class_fare = third_class_fare + fare
                        except ValueError:
                             pass
                        #If they survived add them to the variable
                        if row[1] == '1':
                            third_class_survived = third_class_survived + 1
     
     #Find the averages of the fares and survival rates for first, second, and third class
     avg_first_class_survival_rate = first_class_survived/first_class
     avg_second_class_survival_rate = second_class_survived/second_class
     avg_third_class_survival_rate = third_class_survived/third_class


     avg_first_class_fare = first_class_fare/first_class
     avg_second_class_fare = second_class_fare/second_class
     avg_third_class_fare = third_class_fare/third_class

     #Columsn to add to a new csv file (:.2f makes it so only 2 points over are printed)
     columns = f'''Survival Rate of First Class, Survival Rate of Second Class, Survival Rate of Third Class, Average Fare of First Class, Average Fare of Second Class, Average Fare of Third Class,
     {(avg_first_class_survival_rate*100):.2f}, {(avg_second_class_survival_rate*100):.2f}, {(avg_third_class_survival_rate*100):.2f}, {avg_first_class_fare:.2f}, {avg_second_class_fare:.2f}, {avg_third_class_fare:.2f}
     '''
     #Make a new file and put the columns put above in
     with open('Class_Analysis.csv', 'w') as Class_file:
          Class_file.write(columns)

def famanalysis(file):
     '''
    Desc: Figures out survival rate of people traveling with families vs without
    Args: file(csv)
    Returns: family_analysis.csv (csv)
    
    '''
     #Go to the top of the file
     file.seek(1)
     non_family = 0
     non_family_survived = 0
     family_ppl = 0
     family_ppl_survived = 0

     #For every passanger
     for line in file:
               #If there is an issue with the column not being able to be turned into an int
               try:
                    #devide the line
                    row = line.strip().split(',')
                    #The size of the family to found by combining th esiblings in row 7 and parents/children in row 8
                    family_size = int(row[7]) + int(row[8])
                    #if the passanger has a family member with them
                    if family_size > 0:
                         #They are a family person
                         family_ppl = family_ppl + 1
                         #If they survived
                         if row[1] == '1':
                              family_ppl_survived = family_ppl_survived + 1
                    #If they were alone
                    else:
                         non_family = non_family + 1
                         #If they sruvived
                         if row[1] == '1':
                              non_family_survived = non_family_survived + 1
               except ValueError:
                    pass
     #Find percentage of people with and without families who survived
     family_survival_rate = (family_ppl_survived/family_ppl)*100
     non_family_survival_rate = (non_family_survived/non_family)*100
     #make columns that will be added to new csv file
     columns = f'''Survival Rate of Families, Survival Rate of Solo Passangers,
     {(family_survival_rate):.2f}%, {(non_family_survival_rate):.2f}%
     '''
     #make a new csv file and add the column above
     with open('Family_Analysis.csv', 'w') as Fam_file:
          Fam_file.write(columns)

